{
  "name": "@aresgott/polish",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "Polish — fix grammar, set tone, copy to clipboard (ChatGPT or Claude)",
  "type": "module",
  "bin": {
    "polish": "./dist/cli.js"
  },
  "files": [
    "dist",
    ".npmrc",
    "logo.png",
    "README.md"
  ],
  "scripts": {
